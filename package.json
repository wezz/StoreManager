{
  "name": "@wezz/store-manager",
  "version": "0.1.7",
  "description": "A script to manage local and session storage",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare": "npm run build",
    "pack": "npm run build",
    "trypublish": "npm publish --access public || true",
    "eslint": "eslint --ext .ts --fix",
    "prettier": "prettier --write \"**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wezz/StoreManager.git"
  },
  "author": "Wezz Balk <github@wezz.se> (https://github.com/wezz)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wezz/StoreManager/issues"
  },
  "homepage": "https://github.com/wezz/StoreManager",
  "keywords": [
    "helper",
    "localstorage",
    "sessionstorage",
    "window"
  ],
  "devDependencies": {
    "@eslint/js": "~9.25.1",
    "@types/node": "~22.14.1",
    "eslint": "~9.25.1",
    "prettier": "~3.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "~8.31.0",
    "vite": "~6.3.2",
    "vite-plugin-dts": "~4.5.3"
  }
}
